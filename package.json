{
  "name": "google-drive-media-streamer",
  "version": "1.0.0",
  "description": "Stream Google Drive video files locally to video players like VLC on macOS",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.driveplayer.app",
    "productName": "DrivePlayer",
    "directories": {
      "output": "dist-pack"
    },
    "mac": {
      "category": "public.app-category.video",
      "icon": "icon.png",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "title": "DrivePlayer",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 410,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 130,
          "y": 150,
          "type": "file"
        }
      ]
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^26.15.3"
  }
}
